# Required
TELEGRAM_BOT_TOKEN=
ALFRED_PAYMENT_LINK=https://buy.stripe.com/aFa6oHamC1SO7Ds2h21oI00

# Optional: persistent store override. On Railway, attaching a volume is enough;
# Alfred automatically uses Railway's RAILWAY_VOLUME_MOUNT_PATH.
ALFRED_DATA_DIR=

# Optional: poll a mailbox for forwarded Tesco receipts.
IMAP_HOST=imap.gmail.com
IMAP_USER=
IMAP_PASS=
IMAP_TO=
IMAP_POLL_SECONDS=10

# Optional: how often Alfred checks for the 1h, 2h, and 4h payment nudges.
ALFRED_NUDGE_SCAN_SECONDS=60

# Optional: use Mubit in addition to the local JSON memory.
MUBIT_API_KEY=
MUBIT_ENDPOINT=https://api.mubit.ai
